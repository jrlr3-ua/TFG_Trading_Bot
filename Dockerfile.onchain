# Dockerfile para el Motor de Datos On-Chain & Macro
# Contenedor ligero que descarga Fear & Greed Index, BTC Dominance
# y otros datos macroeconómicos cada 15 minutos.
FROM python:3.10-slim

RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir \
    requests \
    pandas \
    sqlalchemy \
    psycopg2-binary

COPY data_engineering/onchain_ingestor.py .

CMD ["python", "onchain_ingestor.py"]
