# ==========================================
# TFG Trading Bot — Variables de Entorno
# ==========================================
# Copia este fichero como .env y rellena con tus valores reales:
#   cp .env.example .env
#
# ¡NUNCA subas el fichero .env a Git!
# Está protegido por .gitignore.
# ==========================================

# --- BASE DE DATOS (TimescaleDB / PostgreSQL) ---
# Contraseña de acceso para el usuario 'postgres'.
POSTGRES_PASSWORD=cambia_esta_contraseña

# Nombre de la base de datos que usará el bot.
POSTGRES_DB=freqtrade

# --- GRAFANA ---
# Contraseña para el panel de administración de Grafana (usuario: admin).
GF_SECURITY_ADMIN_PASSWORD=cambia_esta_contraseña
